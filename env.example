# Copy to .env in the repo root (loaded by the server on startup).

# Ollama HTTP API (no trailing slash)
OLLAMA_HOST=http://127.0.0.1:11434

# Express API port
PORT=3001

# Optional: set when the web app is not served via Vite proxy (e.g. production).
# Leave unset for local dev — Vite proxies /api to the server.
# VITE_API_URL=http://127.0.0.1:3001
